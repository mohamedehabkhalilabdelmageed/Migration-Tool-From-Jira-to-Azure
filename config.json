        "target": "Microsoft.VSTS.Scheduling.StoryPoints",
        "for": "User Story",
        "type": "string"
      },
      {
        "source": "customfield_10526",
        "target": "Microsoft.VSTS.Common.AcceptanceCriteria",
        "for": "User Story",
        "mapper": "MapRendered"
      },
      {
        "source": "description",
        "target": "System.Description",
